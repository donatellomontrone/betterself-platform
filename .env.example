NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-calendly-user/betterself-home-treatment
CALENDLY_WEBHOOK_SIGNING_KEY=replace_with_calendly_signing_key
# Server-only Calendly Personal Access Token used to sync booked calls when
# webhooks are unavailable on the current Calendly plan.
CALENDLY_ACCESS_TOKEN=
# Optional shared video-call URL used as a doctor fallback when Calendly does
# not store a per-booking call link.
NEXT_PUBLIC_DOCTOR_VIDEO_CALL_URL=
# Google Maps key for the booking address search (Places API (New) enabled + billing).
# If unset, the address field falls back to a plain text input.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Optional public contact details shown in the footer (leave blank to hide a row).
NEXT_PUBLIC_SUPPORT_EMAIL=
NEXT_PUBLIC_SUPPORT_PHONE=
NEXT_PUBLIC_WHATSAPP_URL=
DATABASE_URL=postgres://user:password@host.neon.tech/dbname?sslmode=require
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
PAYMONGO_SECRET_KEY=sk_test_replace_me
PAYMONGO_WEBHOOK_SECRET=whsec_replace_me
# Server-only keys for AI treatment suggestions from the patient's concern.
# Anthropic is preferred to match the Costarax setup. OpenAI is an optional
# secondary provider. If neither is set, booking uses a local safe fallback.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Optional dedicated pepper for pseudonymizing rate-limit identifiers. When
# unset, the server uses an existing private server credential as the pepper.
RATE_LIMIT_HASH_SECRET=
# Comma-separated emails allowed into the /admin doctor dashboard (server-only).
ADMIN_EMAILS=
